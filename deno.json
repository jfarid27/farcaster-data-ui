{
  "tasks": {
      "dev": "deno task server:start & sleep 2 && deno run -A npm:vite",
      "build": "deno run -A npm:vite build",
      "server:start": "deno run --env-file=.env -A --watch ./server/main.ts ",
      "serve": "deno task build && deno task server:start"
  },
  "nodeModulesDir": "auto",
  "compilerOptions": {
      "types": [
          "react",
          "react-dom",
          "@types/react"
      ],
      "lib": [
          "dom",
          "dom.iterable",
          "deno.ns"
      ],
      "jsx": "react-jsx",
      "jsxImportSource": "react"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1"
  }
}


